{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "emitDeclarationOnly": true,
    "outDir": "./dist-tsnode"
  },
  "include": ["vite.config.ts", "api"]
}
